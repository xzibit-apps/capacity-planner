# Capacity Planner — Environment Variables
# Copy to .env.local for local development.
# All production values are managed in Vercel's environment variable settings.

# ─── Auth (CRITICAL) ──────────────────────────────────────────────────────────
# Must match the JWT_SECRET used by the Xzibit Launcher to sign auth_token cookies.
# Without this, every /api/* call returns 500 in production.
JWT_SECRET=<matches-launcher-jwt-secret>

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://rklzgzyqbajhpjvixlkr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from-supabase-dashboard>

# ─── Google Sheets integration ────────────────────────────────────────────────
GOOGLE_SHEET_ID=<spreadsheet-id>
GOOGLE_SERVICE_ACCOUNT_TYPE=service_account
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=<project-id>
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=<key-id>
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=<private-key-with-newlines-as-\\n>
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=<service-account-email>
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=<client-id>

# ─── Build metadata (set by Vercel, not manually) ─────────────────────────────
NEXT_PUBLIC_COMMIT_SHA=unknown
NEXT_PUBLIC_COMMIT_REF=local
NEXT_PUBLIC_BUILD_ENV=local

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_XZIBIT_APPS_URL=http://localhost:3000
